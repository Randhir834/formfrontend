# Frontend Environment Variables

# Backend API URL
# For production (Render deployment):
REACT_APP_API_URL=https://formbackend-1-v0n3.onrender.com/api

# For local development with deployed backend:
# REACT_APP_API_URL=https://formbackend-1-v0n3.onrender.com/api

# For local development with local backend:
# REACT_APP_API_URL=http://localhost:5001/api

# Note: React apps need to be REBUILT after changing environment variables
# On Render, trigger a new deployment after updating environment variables
